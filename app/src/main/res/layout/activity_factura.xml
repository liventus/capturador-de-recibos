<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Factura"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <!-- VISTA PREVIA DE CÁMARA -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="16dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:id="@+id/imgFactura"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />
        </FrameLayout>

        <Button
            android:id="@+id/btnTomarFoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="📷 Tomar foto"/>

        <TextView
            android:id="@+id/txtNumeroDetectado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Factura detectada: -"
            android:textColor="#5E35B1"
            android:textStyle="bold"/>

        <!-- DATOS FACTURA -->

        <EditText
            android:id="@+id/edtNumeroFactura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Número Factura"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/edtRucProveedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="RUC Proveedor"/>

        <EditText
            android:id="@+id/edtProveedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Proveedor"/>

        <EditText
            android:id="@+id/edtFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha"/>

        <EditText
            android:id="@+id/edtMonto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Monto"/>

        <EditText
            android:id="@+id/edtObservacion"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="top"
            android:hint="Observaciones"/>

        <Button
            android:id="@+id/btnGuardarFactura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Guardar Factura"/>

    </LinearLayout>

</ScrollView>