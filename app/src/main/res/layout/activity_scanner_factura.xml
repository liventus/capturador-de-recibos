<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarScanner"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/abc_ic_ab_back_material"
        app:title="Scanner Factura"
        app:titleTextColor="#000000" />

    <!-- Camera Container -->
    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#F5F5F5"
        app:layout_constraintBottom_toTopOf="@+id/bottomSheet"
        app:layout_constraintTop_toBottomOf="@id/toolbarScanner">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/btnStartCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_logo_card"
                android:backgroundTint="#FF9800"
                android:gravity="center"
                android:text="📷"
                android:textSize="32sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abrir Cámara"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Viewfinder Overlay -->
        <LinearLayout
            android:id="@+id/viewfinder"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="100dp"
                app:cardBackgroundColor="#00000000"
                app:strokeColor="#FF9800"
                app:strokeWidth="2dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Apunta al número de comprobante"
                    android:textColor="#FF9800"
                    android:textSize="12sp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="F001-XXXXXXXX • B001-XXXXXXXX"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

    </FrameLayout>

    <!-- Bottom Result Info -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        android:layout_marginBottom="-24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeWidth="1dp"
        app:strokeColor="#EEEEEE">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingBottom="48dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelDetectada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Factura detectada"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_logo_card"
                    android:backgroundTint="#E8F5E9"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="SUNAT ✓"
                    android:textColor="#2E7D32"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetectedFactura"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/labelDetectada"
                    android:layout_marginTop="4dp"
                    android:text="F001-00001234"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Details Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8F9FA"
                android:padding="12dp"
                android:layout_marginBottom="24dp">

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emisor" android:textColor="#888888" android:textSize="12sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Honda del Perú SAC" android:textColor="#000000" android:textStyle="bold" android:textSize="12sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RUC" android:textColor="#888888" android:textSize="12sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="20100111388" android:textColor="#FF9800" android:textStyle="bold" android:textSize="12sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Estado" android:textColor="#888888" android:textSize="12sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="ACTIVO - HABIDO" android:textColor="#4CAF50" android:textStyle="bold" android:textSize="12sp" />
                </RelativeLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Pre-llenar formulario de recepción"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="#FF9800" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>