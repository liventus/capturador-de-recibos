<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/abc_ic_ab_back_material"
                app:tint="#000000"
                android:layout_centerVertical="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recepción de motos"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Borrador guardado"
                android:textColor="#FF9800"
                android:textSize="10sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_logo_card"
                android:backgroundTint="#20FF9800"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Steps -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#FF9800" android:layout_marginEnd="4dp" />
            <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#FF9800" android:layout_marginEnd="4dp" />
            <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#EEEEEE" android:layout_marginEnd="4dp" />
            <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#EEEEEE" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Proveedor" android:textColor="#888888" android:textSize="12sp" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Moto" android:textColor="#FF9800" android:textSize="12sp" android:gravity="center" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Precio" android:textColor="#888888" android:textSize="12sp" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fotos" android:textColor="#888888" android:textSize="12sp" android:gravity="center" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paso 2 de 4 — Datos de la moto"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Form Fields -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIN • Escaneado"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#F8F9FA"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#FF9800"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/etVin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="JHM CB 7652 MC 000001"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔳" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="32dp">

            <!-- Marca -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Marca" android:textColor="#000000" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_card_home"
                    android:backgroundTint="#F8F9FA"
                    android:padding="16dp"
                    android:text="Honda"
                    android:textColor="#000000" />
            </LinearLayout>

            <!-- Modelo -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Modelo" android:textColor="#000000" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_card_home"
                    android:backgroundTint="#F8F9FA"
                    android:padding="16dp"
                    android:text="CB500X"
                    android:textColor="#000000" />
            </LinearLayout>

            <!-- Año -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Año" android:textColor="#000000" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_card_home"
                    android:backgroundTint="#F8F9FA"
                    android:padding="16dp"
                    android:text="2024"
                    android:textColor="#000000" />
            </LinearLayout>

            <!-- Color -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Color" android:textColor="#000000" android:textSize="14sp" android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_card_home"
                    android:backgroundTint="#F8F9FA"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <View android:layout_width="16dp" android:layout_height="16dp" android:background="#000000" android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Negro" android:textColor="#000000" />
                </LinearLayout>
            </LinearLayout>

        </GridLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnterior"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Anterior"
                android:textAllCaps="false"
                android:textColor="#000000"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="16dp"
                android:layout_marginEnd="8dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="2"
                android:text="Guardar"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textStyle="bold"
                app:backgroundTint="#FF9800"
                app:cornerRadius="16dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>