<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo oscuro cuadrado/redondeado -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22103E"/> <!-- El color de tu ic_launcher_background -->
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- El dibujo del vehículo -->
    <item
        android:drawable="@drawable/ic_launcher_foreground"
        android:top="12dp"
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp" />
</layer-list>
